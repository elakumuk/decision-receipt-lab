{
  "name": "ovrule-lab",
  "version": "0.3.0",
  "description": "TypeScript SDK for Ovrule — accountability guardrails for AI agents: classify an action, guard a tool call (incl. the accounts-payable / payment-fraud pack), and verify signed receipts.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "bin/ovrule-lab",
    "bin/welcome.js"
  ],
  "bin": {
    "ovrule-lab": "./bin/ovrule-lab"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "ovrule",
    "ai-governance",
    "ai-audit",
    "agent-safety",
    "receipt-verification",
    "typescript-sdk"
  ],
  "license": "MIT",
  "sideEffects": false,
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
